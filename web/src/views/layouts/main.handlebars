<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BichoHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/custom.css">
    <link rel="icon" href="/img/bitmap.svg">
    <script src="https://accounts.google.com/gsi/client" async defer></script>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-light bg-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <img src="/img/logo.svg" height="70px"/>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    {{#if logado}}
                        <li class="nav-item">
                            <a class="nav-link" href="/ocorrencias/abertas">Abertas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/ocorrencias/listar">Listar ocorrências</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/ocorrencias/mapa">Mapa</a>
                        </li>
                        {{#if eh_admin}}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Admin</a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/admin/dashboard">Dashboard</a></li>
                                <li><a class="dropdown-item" href="/admin/ocorrencias">Ocorrências</a></li>
                                <li><a class="dropdown-item" href="/admin/usuarios">Usuários</a></li>
                            </ul>
                        </li>
                        {{/if}}
                        <li class="nav-item">
                            <a class="nav-link" href="/logout">Sair</a>
                        </li>
                    {{/if}}
                    <li class="nav-item">
                        <a class="nav-link" href="/sobre">Sobre</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-2">
        {{{body}}}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
