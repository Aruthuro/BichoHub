<div class="d-flex justify-content-between align-items-center mb-4">
  <h3>Ocorrências Abertas</h3>
</div>

{{#if erro}}
<div class="alert alert-danger">{{erro}}</div>
{{/if}}

<div class="row row-cols-1 row-cols-md-2 g-4">
  {{#each ocorrencias}}
  <div class="col">
    <div class="card h-100 shadow-sm border-{{#if ultimo_caso}}danger{{else}}primary{{/if}}">
      <div class="card-header {{#if ultimo_caso}}bg-danger{{else}}bg-primary{{/if}} text-white d-flex justify-content-between">
        <span>ID: {{id}}</span>
        {{#if ultimo_caso}}<span class="badge bg-white text-danger">Última ocorrência</span>{{/if}}
      </div>
      <div class="card-body">
        <h5 class="card-title">Tipo: {{tipo}}</h5>
        <p class="card-text"><strong>Solicitante:</strong> {{solicitante_nome}}</p>
        <p class="card-text"><strong>Data:</strong> {{data_captura}}</p>
        <p class="card-text"><strong>Origem:</strong> {{descricao_origem}}</p>
        <p class="card-text text-truncate"><strong>Obs:</strong> {{observacoes}}</p>
        <div class="mt-3">
          <span class="badge bg-secondary">Risco: {{risco}}</span>
        </div>
      </div>
      <div class="card-footer bg-transparent border-0 d-flex flex-column gap-2">
        <a href="/ocorrencias/{{id}}" class="btn btn-outline-primary">Ver Detalhes</a>
        <form action="/ocorrencias/responder/{{id}}" method="POST" class="d-grid">
            <input type="hidden" name="resposta" value="aceitar">
            <button type="submit" class="btn btn-success">Aceitar Chamada</button>
        </form>
      </div>
    </div>
  </div>
  {{else}}
  <div class="col-12">
    <div class="alert alert-info text-center">Nenhuma ocorrência aberta no momento.</div>
  </div>
  {{/each}}
</div>
