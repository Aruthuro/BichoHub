<div class="mb-4 d-flex align-items-center gap-3">
  <a href="javascript:history.back()" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
  <h3>Detalhes da Ocorrência #{{ocorrencia.id}}</h3>
</div>

<div class="row g-4">
  <div class="col-md-8">
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Informações Gerais</h5>
        <span class="badge {{#if (eq ocorrencia.estado 0)}}bg-danger{{else if (eq ocorrencia.estado 2)}}bg-warning text-dark{{else if (eq ocorrencia.estado 3)}}bg-success{{else if (eq ocorrencia.estado 5)}}bg-info{{/if}}">
          {{#if (eq ocorrencia.estado 0)}}Aberta{{else if (eq ocorrencia.estado 2)}}Em Andamento{{else if (eq ocorrencia.estado 3)}}Encerrada{{else if (eq ocorrencia.estado 5)}}Sob Cuidados{{/if}}
        </span>
      </div>
      <div class="card-body">
        <div class="row mb-3">
          <div class="col-sm-4 fw-bold">Tipo:</div>
          <div class="col-sm-8">{{ocorrencia.tipo}}</div>
        </div>
        <div class="row mb-3">
          <div class="col-sm-4 fw-bold">Data de Captura:</div>
          <div class="col-sm-8">{{ocorrencia.data_captura}}</div>
        </div>
        <div class="row mb-3">
          <div class="col-sm-4 fw-bold">Solicitante:</div>
          <div class="col-sm-8">{{ocorrencia.solicitante_nome}} ({{ocorrencia.solicitante_contato}})</div>
        </div>
        <div class="row mb-3">
          <div class="col-sm-4 fw-bold">Local de Origem:</div>
          <div class="col-sm-8">{{ocorrencia.descricao_origem}}</div>
        </div>
        <div class="row mb-3">
          <div class="col-sm-4 fw-bold">Coordenadas (GPS):</div>
          <div class="col-sm-8">{{ocorrencia.origem_gps}}</div>
        </div>
        <hr>
        <div class="row mb-3">
          <div class="col-sm-4 fw-bold">Observações:</div>
          <div class="col-sm-8">{{ocorrencia.observacoes}}</div>
        </div>
        <div class="row mb-3">
          <div class="col-sm-4 fw-bold">Risco:</div>
          <div class="col-sm-8">{{ocorrencia.risco}}</div>
        </div>
      </div>
    </div>

    {{#if ocorrencia.referencia_imagem}}
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-light">
        <h5 class="mb-0">Imagem da Ocorrência</h5>
      </div>
      <div class="card-body text-center">
        <img src="data:image/jpeg;base64,{{ocorrencia.referencia_imagem}}" class="img-fluid rounded" alt="Imagem da ocorrência" style="max-height: 400px;">
      </div>
    </div>
    {{/if}}

    {{#if (or (eq ocorrencia.estado 2) (eq ocorrencia.estado 5))}}
    <div class="card shadow-sm">
      <div class="card-header bg-warning-subtle">
        <h5 class="mb-0">Atualizar Status</h5>
      </div>
      <div class="card-body">
        <form action="/ocorrencias/editar/{{ocorrencia.id}}" method="POST">
          <div class="mb-3">
            <label class="form-label">Estado</label>
            <select name="estado" class="form-select">
              <option value="2" {{#if (eq ocorrencia.estado 2)}}selected{{/if}}>Em Andamento</option>
              <option value="5" {{#if (eq ocorrencia.estado 5)}}selected{{/if}}>Animal sob cuidados</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Status de Saúde</label>
            <input type="text" name="status_saude" class="form-control" value="{{ocorrencia.status_saude}}">
          </div>
          <button type="submit" class="btn btn-warning">Salvar Alterações</button>
        </form>
      </div>
    </div>
    {{/if}}
  </div>

  <div class="col-md-4">
    {{#if (eq ocorrencia.estado 0)}}
    <div class="card shadow-sm border-success">
      <div class="card-body">
        <h5 class="card-title">Disponível</h5>
        <p class="card-text text-muted">Esta ocorrência ainda não foi aceita por nenhum coletor.</p>
        <form action="/ocorrencias/responder/{{ocorrencia.id}}" method="POST">
          <input type="hidden" name="resposta" value="aceitar">
          <button type="submit" class="btn btn-success w-100">Aceitar Chamada</button>
        </form>
      </div>
    </div>
    {{/if}}

    {{#if ocorrencia.classificacao}}
    <div class="card shadow-sm border-info mt-3">
      <div class="card-body">
        <h5 class="card-title text-info">Classificação</h5>
        <p class="card-text">
          <strong>Animal:</strong> {{ocorrencia.classificacao}}<br>
          <strong>Confiança:</strong> {{ocorrencia.confianca_classificacao}}%
        </p>
      </div>
    </div>
    {{/if}}

    {{#if (or (eq ocorrencia.estado 2) (eq ocorrencia.estado 5))}}
    <div class="card shadow-sm border-danger mt-3">
      <div class="card-body">
        <h5 class="card-title text-danger">Encerrar Chamada</h5>
        <form action="/ocorrencias/encerrar/{{ocorrencia.id}}" method="POST">
          <div class="mb-3">
            <label class="form-label">Desfecho</label>
            <select name="desfecho" class="form-select" required>
              <option value="">Selecione...</option>
              <option value="solto">Solto</option>
              <option value="sob_cuidados">Sob Cuidados</option>
              <option value="morto">Morto</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Descrição Soltura</label>
            <textarea name="descricao_soltura" class="form-control" rows="2"></textarea>
          </div>
          <button type="submit" class="btn btn-danger w-100">Finalizar Ocorrência</button>
        </form>
      </div>
    </div>
    {{/if}}
  </div>
</div>
